---
import type { CollectionEntry } from 'astro:content'

import BlogHero from '@/components/blog/Hero.astro'
import Upvote from '@/components/Upvote.tsx'
import PageLayout from './BaseLayout.astro'

interface Props {
	post: CollectionEntry<'post'>
}

const { post } = Astro.props
const {
	data: { description, ogImage, publishDate, title, updatedDate },
	slug
} = post

const socialImage = ogImage ?? `/og-image/${slug}.png`
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
---

<PageLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
	<a href='/' id='post-back' aria-label='Back to home'>← Akshat Mahajan</a>

	<article id='post' data-pagefind-body aria-label={title}>
		<div id='blog-hero'><BlogHero content={post} /></div>
		<slot />
		<div id='post-footer'>
			<Upvote client:load postId={post.id} /> · Subscribe to my <a href='/rss.xml'>RSS feed</a>.
		</div>
	</article>
</PageLayout>

<script>
	const scrollBtn = document.getElementById('to-top-btn') as HTMLButtonElement | null
	const targetHeader = document.getElementById('blog-hero') as HTMLDivElement | null

	if (scrollBtn && targetHeader) {
		scrollBtn.addEventListener('click', () => {
			document.documentElement.scrollTo({ behavior: 'smooth', top: 0 })
		})
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				scrollBtn.dataset.show = (!entry.isIntersecting).toString()
			})
		})
		observer.observe(targetHeader)
	}
</script>

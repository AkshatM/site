---
import { cn } from '@/utils'

const { class: className, title } = Astro.props
---

<section class={cn(className, 'flex flex-col gap-y-6 md:flex-row md:gap-x-12 md:gap-y-0')}>
	<div class='md:w-1/4 shrink-0'>
		<h2 class='text-xl font-semibold tracking-tight text-foreground'>{title}</h2>
	</div>
	<div class='flex flex-col gap-y-4 md:w-3/4'>
		<slot />
	</div>
</section>

---
import PageLayout from '../layouts/BaseLayout.astro'
import FormattedDate from '@/components/FormattedDate.astro'

import { getAllPosts, sortMDByDate } from '@/utils'

const allPosts = await getAllPosts()
const allPostsByDate = sortMDByDate(allPosts)
---

<PageLayout meta={{ title: 'Home' }}>
	<div id='home'>
		<div id='home-body'>
			<h1>$ objdump -s 'Akshat Mahajan'</h1>
			<p id='home-role'>Senior Software Engineer · Boston, MA</p>

			<div id='home-bio'>
				<h3><a href='https://share.google/aimode/x7FA7LYNqQsFphw2M'><code>.data</code></a></h3>
				<p>I turn complex distributed systems into simple, reliable APIs.</p>
				<p>
					Over the last seven years, I've built routing protocols, data pipelines, platform
					automations, privacy-preserving mechanisms, and orchestrators. I've run out of inodes,
					seen packet corruption in real time, and learned why SSH breaks when you
					<code>chmod 777 ~</code>.
				</p>
				<p>
					Currently I work at <b>Cloudflare</b> on the <a
						href='https://www.cloudflare.com/privacy-platform/'>Privacy Edge</a
					> team. I wrote and deployed the first <a
						href='https://github.com/cloudflare/web-bot-auth'>Rust implementation</a
					> for <a href='https://datatracker.ietf.org/wg/webbotauth/about/'>Web Bot Auth</a>,
					powering Cloudflare's agent detection.
				</p>
				<p>
					I care about good abstractions. I like getting close to the bits, understanding how things
					behave under real constraints, and refining interfaces until they feel inevitable. But
					formal elegance feels artificial to me. There is no better feeling than actually solving
					someone’s problem.
				</p>
			</div>

			<h3>
				<a href='https://share.google/aimode/futNbCmu63BwVKavZ'><code>.bss</code></a>
			</h3>
			<p>
				I'm learning more about <a href='https://webrtcforthecurious.com/'>WebRTC</a> and inference engines
				like <a href='https://github.com/vllm-project/vllm'>vLLM</a>.
			</p>

			<h3>
				<a href='https://share.google/aimode/wluFHuuRuE9bXDzVL'><code>.text</code></a>
			</h3>
			{
				allPostsByDate.length > 0 && (
					<section id='home-posts' aria-label='Posts'>
						<ul>
							{allPostsByDate.map((p) => {
								const date = p.data.updatedDate ?? p.data.publishDate
								return (
									<li>
										<FormattedDate date={date} />
										<div>
											<a data-astro-prefetch href={`/blog/${p.slug}/`}>
												{p.data.title}
											</a>
											{p.data.description && <p class='post-desc'>{p.data.description}</p>}
										</div>
									</li>
								)
							})}
						</ul>
					</section>
				)
			}
		</div>

		<nav id='home-nav' aria-label='Site navigation'>
			<ul>
				<li><a href='https://share.google/aimode/mguxifjQz5piy8Hbj'><code>.plt</code></a></li>
				<li><a href='/resume.pdf'>Resume</a></li>
				<li><a href='https://github.com/AkshatM' rel='noopener noreferrer'>GitHub</a></li>
				<li>
					<a href='https://www.linkedin.com/in/mahajanakshat' rel='noopener noreferrer'>LinkedIn</a>
				</li>
				<li><a href='mailto:me@akshatmahajan.com'>Contact</a></li>
			</ul>
		</nav>
	</div>
</PageLayout>
